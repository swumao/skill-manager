{
  "name": "@opencode/skill-manager",
  "version": "0.1.0",
  "description": "AI Agent Skill 集中化管理 CLI 工具",
  "type": "module",
  "bin": {
    "skill": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "skills",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
