    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "picocolors": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swumao/skill-manager.git"
  },
  "homepage": "https://github.com/swumao/skill-manager#readme",
  "bugs": {
    "url": "https://github.com/swumao/skill-manager/issues"
  },
